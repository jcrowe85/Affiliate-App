# Copy to .env.local and fill in. Never commit real values — .env and .env*.local
# are gitignored. Production values belong in your host's environment settings.

# --- Database ---
DATABASE_URL="postgresql://user:password@host:5432/database"

# --- Shopify ---
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_APP_URL="https://your-app-url.com"
SHOPIFY_SHOP_ID="your-shop.myshopify.com"
SHOPIFY_WEBHOOK_SECRET=""
SHOPIFY_SCOPES=""
SHOPIFY_STOREFRONT_ACCESS_TOKEN=""

# --- PayPal payouts ---
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox" # or "live"

# --- Email (Resend) ---
# Transactional email for affiliate signups. If RESEND_API_KEY is unset, email
# is skipped with a warning and everything else keeps working.
RESEND_API_KEY=""
# Must be on a domain verified in Resend, or sends are rejected. Note that
# verifying a subdomain does not authorize the apex domain, or vice versa.
RESEND_FROM_EMAIL="Fleur Affiliates <team@resend.yourdomain.com>"
# Where "new application" notices go. Comma-separate for more than one
# recipient. Defaults to the first admin user's email when blank.
ADMIN_NOTIFICATION_EMAIL="you@yourdomain.com,teammate@yourdomain.com"
