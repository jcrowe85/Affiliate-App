generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Affiliate {
  id                          String                    @id @default(cuid())
  name                        String
  email                       String                    @unique
  status                      String                    @default("active")
  payout_method               String?
  payout_identifier           String?
  payout_terms_days           Int                       @default(30)
  shopify_shop_id             String
  created_at                  DateTime                  @default(now())
  updated_at                  DateTime                  @updatedAt
  address_line1               String?
  address_line2               String?
  affiliate_number            Int?
  city                        String?
  company                     String?
  first_name                  String?
  last_name                   String?
  merchant_id                 String?
  offer_id                    String?
  password_hash               String?
  paypal_email                String?
  phone                       String?
  postback_affiliate_id       String?
  postback_sub1               String?
  postback_sub2               String?
  postback_sub3               String?
  postback_sub4               String?
  postback_transaction_id     String?
  state                       String?
  webhook_parameter_mapping   Json?
  webhook_url                 String?
  zip                         String?
  redirect_base_url           String?
  source                      String?
  redirect_parameters_enabled Boolean?                  @default(false)
  offer                       Offer?                    @relation(fields: [offer_id], references: [id])
  application                 AffiliateApplication?
  links                       AffiliateLink[]
  affiliate_offers            AffiliateOffer[]
  sessions                    AffiliateSession[]
  affiliate_webhook_logs      AffiliateWebhookLog[]
  clicks                      Click[]
  commissions                 Commission[]
  fraud_flags                 FraudFlag[]
  orders                      OrderAttribution[]
  subscription_attributions   SubscriptionAttribution[]
  VisitorSession              VisitorSession[]

  @@unique([shopify_shop_id, affiliate_number])
  @@unique([shopify_shop_id, merchant_id])
  @@index([shopify_shop_id, status])
  @@index([email])
  @@index([offer_id])
}

model AffiliateApplication {
  id              String     @id @default(cuid())
  first_name      String
  last_name       String
  company         String?
  email           String
  paypal_email    String?
  address_line1   String?
  address_line2   String?
  city            String?
  state           String?
  zip             String?
  phone           String?
  password_hash   String
  status          String     @default("pending")
  shopify_shop_id String
  affiliate_id    String?    @unique
  reviewed_at     DateTime?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  affiliate       Affiliate? @relation(fields: [affiliate_id], references: [id])

  @@index([shopify_shop_id, status])
  @@index([email])
}

model AffiliateLink {
  id              String    @id @default(cuid())
  affiliate_id    String
  destination_url String
  campaign_name   String?
  coupon_code     String?
  shopify_shop_id String
  created_at      DateTime  @default(now())
  affiliate       Affiliate @relation(fields: [affiliate_id], references: [id], onDelete: Cascade)
  clicks          Click[]

  @@index([affiliate_id])
  @@index([shopify_shop_id])
  @@index([coupon_code])
}

model Click {
  id                 String             @id @default(cuid())
  affiliate_id       String
  link_id            String?
  landing_url        String
  ip_hash            String
  user_agent_hash    String
  shopify_shop_id    String
  created_at         DateTime           @default(now())
  url_transaction_id String?
  url_affiliate_id   String?
  url_sub1           String?
  url_sub2           String?
  url_sub3           String?
  url_sub4           String?
  url_params         Json?
  affiliate          Affiliate          @relation(fields: [affiliate_id], references: [id], onDelete: Cascade)
  link               AffiliateLink?     @relation(fields: [link_id], references: [id])
  order_attributions OrderAttribution[]

  @@index([affiliate_id, created_at])
  @@index([shopify_shop_id, created_at])
}

model OrderAttribution {
  id                   String       @id @default(cuid())
  shopify_order_id     String       @unique
  shopify_order_number String
  affiliate_id         String
  click_id             String?
  attribution_type     String
  shopify_shop_id      String
  created_at           DateTime     @default(now())
  customer_email       String?
  customer_name        String?
  order_currency       String?      @default("USD")
  order_total          Decimal?     @db.Decimal(10, 2)
  landing_url_params   Json?
  commissions          Commission[]
  affiliate            Affiliate    @relation(fields: [affiliate_id], references: [id], onDelete: Cascade)
  click                Click?       @relation(fields: [click_id], references: [id])

  @@index([shopify_order_id])
  @@index([affiliate_id])
  @@index([shopify_shop_id])
  @@index([customer_email])
}

model CommissionRule {
  id               String   @id @default(cuid())
  name             String
  rule_type        String
  applies_to       String
  value            Decimal  @db.Decimal(10, 2)
  max_payments     Int?
  max_months       Int?
  selling_plan_ids String?
  active           Boolean  @default(true)
  shopify_shop_id  String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([shopify_shop_id, active])
}

model Commission {
  id                     String                @id @default(cuid())
  affiliate_id           String
  shopify_order_id       String
  order_attribution_id   String
  amount                 Decimal               @db.Decimal(10, 2)
  currency               String                @default("USD")
  status                 String                @default("pending")
  eligible_date          DateTime
  rule_snapshot          Json
  shopify_shop_id        String
  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt
  affiliate_webhook_logs AffiliateWebhookLog[]
  affiliate              Affiliate             @relation(fields: [affiliate_id], references: [id], onDelete: Cascade)
  order_attribution      OrderAttribution      @relation(fields: [order_attribution_id], references: [id], onDelete: Cascade)
  fraud_flags            FraudFlag[]
  payout_run_commissions PayoutRunCommission?
  postback_logs          PostbackLog[]

  @@index([affiliate_id, status])
  @@index([shopify_order_id])
  @@index([status, eligible_date])
  @@index([shopify_shop_id, status])
}

model SubscriptionAttribution {
  id                String    @id @default(cuid())
  original_order_id String
  affiliate_id      String
  selling_plan_id   String
  interval_months   Int
  max_payments      Int?
  payments_made     Int       @default(0)
  active            Boolean   @default(true)
  shopify_shop_id   String
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  affiliate         Affiliate @relation(fields: [affiliate_id], references: [id], onDelete: Cascade)

  @@unique([original_order_id, selling_plan_id])
  @@index([affiliate_id])
  @@index([shopify_shop_id, active])
}

model PayoutRun {
  id               String                @id @default(cuid())
  period_start     DateTime
  period_end       DateTime
  status           String                @default("draft")
  payout_reference String?
  shopify_shop_id  String
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt
  commissions      PayoutRunCommission[]

  @@index([shopify_shop_id, status])
}

model PayoutRunCommission {
  id            String     @id @default(cuid())
  payout_run_id String
  commission_id String     @unique
  created_at    DateTime   @default(now())
  commission    Commission @relation(fields: [commission_id], references: [id], onDelete: Cascade)
  payout_run    PayoutRun  @relation(fields: [payout_run_id], references: [id], onDelete: Cascade)
}

model PostbackTemplate {
  id              String        @id @default(cuid())
  name            String
  base_url        String
  param_mappings  Json
  trigger_event   String
  active          Boolean       @default(true)
  shopify_shop_id String
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  postback_logs   PostbackLog[]

  @@index([shopify_shop_id, active, trigger_event])
}

model PostbackLog {
  id                   String           @id @default(cuid())
  commission_id        String
  postback_template_id String
  status               String
  response_code        Int?
  response_body        String?
  attempts             Int              @default(1)
  last_attempt_at      DateTime         @default(now())
  shopify_shop_id      String
  created_at           DateTime         @default(now())
  commission           Commission       @relation(fields: [commission_id], references: [id], onDelete: Cascade)
  postback_template    PostbackTemplate @relation(fields: [postback_template_id], references: [id], onDelete: Cascade)

  @@index([commission_id])
  @@index([status, last_attempt_at])
}

model AffiliateWebhookLog {
  id              String     @id @default(cuid())
  commission_id   String
  affiliate_id    String
  webhook_url     String
  request_method  String     @default("GET")
  request_body    String?
  response_code   Int?
  response_body   String?
  status          String     @default("pending")
  error_message   String?
  attempts        Int        @default(1)
  last_attempt_at DateTime   @default(now())
  shopify_shop_id String
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  request_params  Json?
  affiliate       Affiliate  @relation(fields: [affiliate_id], references: [id], onDelete: Cascade)
  commission      Commission @relation(fields: [commission_id], references: [id], onDelete: Cascade)

  @@index([commission_id])
  @@index([affiliate_id])
  @@index([status, last_attempt_at])
  @@index([shopify_shop_id])
}

model FraudFlag {
  id              String     @id @default(cuid())
  commission_id   String
  affiliate_id    String
  flag_type       String
  score           Int        @default(0)
  reason          String
  resolved        Boolean    @default(false)
  shopify_shop_id String
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  affiliate       Affiliate  @relation(fields: [affiliate_id], references: [id], onDelete: Cascade)
  commission      Commission @relation(fields: [commission_id], references: [id], onDelete: Cascade)

  @@index([commission_id])
  @@index([affiliate_id, resolved])
  @@index([shopify_shop_id, resolved])
}

model ShopifySession {
  id                      String    @id @unique
  shop                    String
  state                   String?
  is_online               Boolean   @default(false)
  scope                   String?
  expires                 DateTime?
  access_token            String?
  created_at              DateTime  @default(now())
  storefront_access_token String?
  updated_at              DateTime  @updatedAt

  @@index([shop])
}

model AdminUser {
  id              String         @id @default(cuid())
  email           String         @unique
  password_hash   String
  name            String?
  role            String         @default("admin")
  shopify_shop_id String
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  last_login      DateTime?
  sessions        AdminSession[]

  @@index([email])
  @@index([shopify_shop_id])
}

model AdminSession {
  id            String    @id @default(cuid())
  admin_user_id String
  token         String    @unique
  expires_at    DateTime
  created_at    DateTime  @default(now())
  admin_user    AdminUser @relation(fields: [admin_user_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([admin_user_id])
}

model AffiliateSession {
  id           String    @id @default(cuid())
  affiliate_id String
  token        String    @unique
  expires_at   DateTime
  created_at   DateTime  @default(now())
  affiliate    Affiliate @relation(fields: [affiliate_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([affiliate_id])
}

model Offer {
  id                                   String           @id @default(cuid())
  offer_number                         Int?
  name                                 String
  commission_type                      String           @default("flat_rate")
  amount                               Decimal          @db.Decimal(10, 2)
  currency                             String           @default("USD")
  commission_terms                     String?
  attribution_window_days              Int              @default(90)
  auto_approve_affiliates              Boolean          @default(false)
  selling_subscriptions                String           @default("no")
  subscription_max_payments            Int?
  subscription_rebill_commission_type  String?
  subscription_rebill_commission_value Decimal?         @db.Decimal(10, 2)
  make_private                         Boolean          @default(false)
  hide_referral_links                  Boolean          @default(false)
  hide_coupon_promotion                Boolean          @default(false)
  enable_variable_commission           Boolean          @default(false)
  shopify_shop_id                      String
  created_at                           DateTime         @default(now())
  updated_at                           DateTime         @updatedAt
  affiliates                           Affiliate[]
  affiliate_offers                     AffiliateOffer[]

  @@unique([shopify_shop_id, offer_number])
  @@index([shopify_shop_id])
}

model AffiliateOffer {
  id           String    @id @default(cuid())
  affiliate_id String
  offer_id     String
  created_at   DateTime  @default(now())
  affiliate    Affiliate @relation(fields: [affiliate_id], references: [id], onDelete: Cascade)
  offer        Offer     @relation(fields: [offer_id], references: [id], onDelete: Cascade)

  @@unique([affiliate_id, offer_id])
  @@index([affiliate_id])
  @@index([offer_id])
}

model VisitorSession {
  id               String         @id @default(cuid())
  session_id       String         @unique
  visitor_id       String
  shopify_shop_id  String
  entry_page       String
  exit_page        String?
  start_time       DateTime       @default(now())
  end_time         DateTime?
  page_views       Int            @default(0)
  pages_visited    String[]
  total_time       Int?
  is_bounce        Boolean        @default(false)
  device_type      String?
  user_agent       String?
  screen_width     Int?
  screen_height    Int?
  language         String?
  timezone         String?
  referrer_type    String?
  referrer_url     String?
  referrer_domain  String?
  location_country String?
  location_city    String?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  affiliate_id     String?
  affiliate_number Int?
  url_params       Json?
  landing_page     String?
  events           VisitorEvent[]
  Affiliate        Affiliate?     @relation(fields: [affiliate_id], references: [id])

  @@index([visitor_id])
  @@index([shopify_shop_id, start_time])
  @@index([affiliate_id, start_time])
  @@index([shopify_shop_id, created_at])
}

model VisitorEvent {
  id                 String         @id @default(cuid())
  visitor_session_id String
  visitor_id         String
  event_type         String
  shopify_shop_id    String
  page_url           String?
  page_path          String?
  page_title         String?
  referrer           String?
  timestamp          DateTime       @default(now())
  event_data         Json?
  session            VisitorSession @relation(fields: [visitor_session_id], references: [id], onDelete: Cascade)

  @@index([visitor_session_id])
  @@index([shopify_shop_id, timestamp])
}
